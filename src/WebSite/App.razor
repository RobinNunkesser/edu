@inject NavigationManager NavigationManager
@inject SiteContentService ContentService

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>@UiText.NotFoundTitle</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <p role="alert">@UiText.NotFoundText</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private UiTextViewModel UiText = new("Home", "Lehre", "Forschung", "Software", string.Empty, string.Empty, string.Empty, string.Empty, string.Empty, string.Empty, string.Empty, "Nicht gefunden", "Unter dieser Adresse ist kein Inhalt hinterlegt.");

    protected override async Task OnParametersSetAsync()
    {
        var language = SiteRoutes.GetLanguage(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));
        UiText = await ContentService.GetUiTextAsync(language);
    }
}
