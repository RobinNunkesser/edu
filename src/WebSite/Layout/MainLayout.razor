@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager
@inject SiteContentService ContentService

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-title">@CurrentSectionTitle</div>
            <div class="language-switch">
                <a class="@(CurrentLanguage == SiteLanguage.De ? "active-language" : null)" href="@SiteRoutes.SwitchLanguage(RelativePath, SiteLanguage.De)">DE</a>
                <a class="@(CurrentLanguage == SiteLanguage.En ? "active-language" : null)" href="@SiteRoutes.SwitchLanguage(RelativePath, SiteLanguage.En)">EN</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private SiteLanguage CurrentLanguage;
    private string RelativePath = string.Empty;
    private string CurrentSectionTitle = string.Empty;
    private UiTextViewModel UiText = new("Lehre", "Forschung", "Buch", "Software", "Zweisprachiger Prototyp", string.Empty, string.Empty, string.Empty, string.Empty, string.Empty, string.Empty, string.Empty, string.Empty);

    protected override async Task OnInitializedAsync()
    {
        await UpdateRouteStateAsync();
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await UpdateRouteStateAsync(e.Location);
        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdateRouteStateAsync(string? location = null)
    {
        RelativePath = NavigationManager.ToBaseRelativePath(location ?? NavigationManager.Uri);
        CurrentLanguage = SiteRoutes.GetLanguage(RelativePath);
        UiText = await ContentService.GetUiTextAsync(CurrentLanguage);
        CurrentSectionTitle = ResolveCurrentSectionTitle(RelativePath);
    }

    private string ResolveCurrentSectionTitle(string relativePath)
    {
        var normalized = relativePath.Split('?', '#')[0].Trim('/');

        if (string.IsNullOrWhiteSpace(normalized))
        {
            return UiText.NavTeaching;
        }

        var segments = normalized.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var head = CurrentLanguage == SiteLanguage.En && segments.Length > 0
            ? segments.Skip(1).FirstOrDefault() ?? string.Empty
            : segments[0];

        return head.ToLowerInvariant() switch
        {
            "lehre" or "teaching" or "study" => UiText.NavTeaching,
            "forschung" or "research" => UiText.NavResearch,
            "buch" or "book" => UiText.NavBook,
            "software" => UiText.NavSoftware,
            _ => UiText.NavTeaching
        };
    }
}
