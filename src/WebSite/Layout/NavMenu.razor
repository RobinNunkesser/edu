@implements IDisposable
@inject NavigationManager NavigationManager
@inject SiteContentService ContentService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="@SiteRoutes.Home(CurrentLanguage)">edu</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@SiteRoutes.Home(CurrentLanguage)" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> @UiText.NavHome
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@SiteRoutes.Teaching(CurrentLanguage)">
                <span class="bi bi-journal-richtext" aria-hidden="true"></span> @UiText.NavTeaching
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@SiteRoutes.Research(CurrentLanguage)">
                <span class="bi bi-diagram-3" aria-hidden="true"></span> @UiText.NavResearch
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@SiteRoutes.Software(CurrentLanguage)">
                <span class="bi bi-code-square" aria-hidden="true"></span> @UiText.NavSoftware
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private SiteLanguage CurrentLanguage;
    private UiTextViewModel UiText = new("Home", "Lehre", "Forschung", "Software", string.Empty, string.Empty, string.Empty, string.Empty, string.Empty, string.Empty, string.Empty, string.Empty, string.Empty);

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        await LoadUiAsync(NavigationManager.Uri);
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await LoadUiAsync(e.Location);
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadUiAsync(string location)
    {
        CurrentLanguage = SiteRoutes.GetLanguage(NavigationManager.ToBaseRelativePath(location));
        UiText = await ContentService.GetUiTextAsync(CurrentLanguage);
    }
}
