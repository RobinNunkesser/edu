@page "/buch"
@page "/en/book"
@inject NavigationManager NavigationManager

<PageTitle>Buch</PageTitle>

@code {
    protected override void OnInitialized()
    {
        var language = SiteRoutes.GetLanguage(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));
        NavigationManager.NavigateTo(SiteRoutes.Research(language), true);
    }
}