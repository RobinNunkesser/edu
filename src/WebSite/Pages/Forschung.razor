@page "/forschung"
@page "/en/research"
@inject NavigationManager NavigationManager
@inject SiteContentService ContentService

<PageTitle>Forschung</PageTitle>

@if (Landing is not null)
{
    <section class="page-intro">
        <p class="section-label">@Landing.Label</p>
        <h1>@Landing.Title</h1>
        <p>@Landing.Intro</p>
    </section>

    @if (PublicationsSection is not null && Publications.Count > 0)
    {
        <section class="page-section page-section-muted">
            <div class="section-heading">
                <p class="section-label">@PublicationsSection.Label</p>
                <h2>@PublicationsSection.Title</h2>
                <p>@PublicationsSection.Intro</p>
            </div>

            @foreach (var group in Publications.GroupBy(publication => publication.Category))
            {
                <div class="publication-group">
                    <div class="section-heading publication-group-heading">
                        <p class="section-label">@PublicationsSection.Label</p>
                        <h3>@group.Key</h3>
                    </div>

                    <div class="feature-grid">
                        @foreach (var publication in group.OrderByDescending(item => item.Year).ThenBy(item => item.Title))
                        {
                            <a class="feature-card" href="@NormalizeUrl(publication.Url)" target="_blank" rel="noreferrer">
                                <p class="feature-card-kicker">@publication.Year</p>
                                <h3>@publication.Title</h3>
                                <p class="publication-meta">@publication.Meta</p>
                            </a>
                        }
                    </div>
                </div>
            }
        </section>
    }
}

@code {
    private SiteLanguage CurrentLanguage;
    private SectionLandingViewModel? Landing;
    private SectionLandingViewModel? PublicationsSection;
    private IReadOnlyList<ResearchPublicationViewModel> Publications = [];

    private static string NormalizeUrl(string url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return "#";
        }

        return Uri.TryCreate(url, UriKind.Absolute, out var absoluteUri)
            ? absoluteUri.ToString()
            : url;
    }

    protected override async Task OnParametersSetAsync()
    {
        CurrentLanguage = SiteRoutes.GetLanguage(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));
        Landing = await ContentService.GetResearchLandingAsync(CurrentLanguage);
        PublicationsSection = await ContentService.GetResearchPublicationsSectionAsync(CurrentLanguage);
        Publications = await ContentService.GetResearchPublicationsAsync(CurrentLanguage);
    }
}