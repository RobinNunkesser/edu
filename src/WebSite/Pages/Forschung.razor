@page "/forschung"
@page "/en/research"
@inject NavigationManager NavigationManager
@inject SiteContentService ContentService

<PageTitle>Forschung</PageTitle>

@if (Landing is not null)
{
    <section class="page-intro">
        <p class="section-label">@Landing.Label</p>
        <h1>@Landing.Title</h1>
        <p>@Landing.Intro</p>
    </section>

    <section class="page-section">
        <div class="feature-grid">
            @foreach (var card in Cards)
            {
                <article class="feature-card feature-card-static">
                    <p class="feature-card-kicker">@card.Kicker</p>
                    <h3>@card.Title</h3>
                    <p>@card.Text</p>
                </article>
            }
        </div>
    </section>
}

@code {
    private SiteLanguage CurrentLanguage;
    private SectionLandingViewModel? Landing;
    private IReadOnlyList<InfoCardViewModel> Cards = [];

    protected override async Task OnParametersSetAsync()
    {
        CurrentLanguage = SiteRoutes.GetLanguage(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));
        Landing = await ContentService.GetResearchLandingAsync(CurrentLanguage);
        Cards = await ContentService.GetResearchCardsAsync(CurrentLanguage);
    }
}