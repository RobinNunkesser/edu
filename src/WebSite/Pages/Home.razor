@inject NavigationManager NavigationManager
@inject SiteContentService ContentService

<PageTitle>edu</PageTitle>

@if (HomePage is not null)
{
	<section class="hero">
		<div class="hero-copy">
			<p class="hero-kicker">@HomePage.HeroKicker</p>
			<h1>@HomePage.HeroTitle</h1>
			<p class="hero-lead">@HomePage.HeroLead</p>
		</div>

		<div class="hero-panel">
			<p class="hero-panel-label">@HomePage.FocusLabel</p>
			<h2>@HomePage.FocusTitle</h2>
			<p>@HomePage.FocusText</p>
		</div>
	</section>

	<section class="page-section">
		<div class="section-heading">
			<p class="section-label">@HomePage.NavigationLabel</p>
			<h2>@HomePage.NavigationTitle</h2>
			<p>@HomePage.NavigationText</p>
		</div>

		<div class="feature-grid">
			@foreach (var area in Areas)
			{
				<a class="feature-card" href="@area.Route">
					<p class="feature-card-kicker">@string.Join(" / ", area.Highlights)</p>
					<h3>@area.Title</h3>
					<p>@area.Summary</p>
				</a>
			}
		</div>
	</section>

	<section class="page-section page-section-muted">
		<div class="section-heading">
			<p class="section-label">@HomePage.NextLabel</p>
			<h2>@HomePage.NextTitle</h2>
			<p>@HomePage.NextText</p>
		</div>
	</section>
}

@code {
	private SiteLanguage CurrentLanguage;
	private HomePageViewModel? HomePage;
	private IReadOnlyList<HomeAreaViewModel> Areas = [];

	protected override async Task OnParametersSetAsync()
	{
		CurrentLanguage = SiteRoutes.GetLanguage(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));
		HomePage = await ContentService.GetHomePageAsync(CurrentLanguage);
		Areas = await ContentService.GetAreasAsync(CurrentLanguage);
	}
}
