@page "/lehre/{Slug}"
@page "/en/teaching/{Slug}"
@inject NavigationManager NavigationManager
@inject SiteContentService ContentService

<PageTitle>Lehrveranstaltung</PageTitle>

@if (_lecture is null)
{
    <section class="page-intro">
        <p class="section-label">@(CurrentLanguage == SiteLanguage.En ? "Teaching" : "Lehre")</p>
        <h1>@(CurrentLanguage == SiteLanguage.En ? "Course not found" : "Lehrveranstaltung nicht gefunden")</h1>
        <p>@(CurrentLanguage == SiteLanguage.En ? "No course page has been mapped to this route yet." : "Fuer diese Route ist noch keine Unterseite hinterlegt.")</p>
    </section>
}
else
{
    <section class="page-intro lecture-hero">
        <div>
            <p class="section-label">@(CurrentLanguage == SiteLanguage.En ? "Teaching" : "Lehre")</p>
            <h1>@_lecture.Title</h1>
            <p>@_lecture.Summary</p>
        </div>

        <div class="lecture-meta-card">
            <p class="feature-card-kicker">@(CurrentLanguage == SiteLanguage.En ? "Overview" : "Rahmen")</p>
            <h2>@_lecture.Semester</h2>
            <a class="inline-link" href="@_lecture.SourceUrl" target="_blank" rel="noreferrer">@(CurrentLanguage == SiteLanguage.En ? "Source in lectures wiki" : "Quelle im lectures-Wiki")</a>
        </div>
    </section>

    <section class="page-section">
        <div class="tag-row">
            @foreach (var tag in _lecture.HighlightTags)
            {
                <span class="tag">@tag</span>
            }
        </div>
    </section>

    @foreach (var lectureSection in _lecture.Sections)
    {
        <section class="page-section">
            <div class="section-heading">
                <h2>@lectureSection.Title</h2>
                <p>@lectureSection.Intro</p>
            </div>

            <div class="resource-grid">
                @foreach (var link in lectureSection.Links)
                {
                    <article class="resource-card">
                        <h3>@link.Title</h3>
                        <p>@link.Description</p>
                        @if (string.IsNullOrWhiteSpace(link.Url))
                        {
                            <span class="resource-inline-note">@(CurrentLanguage == SiteLanguage.En ? "Documented directly on the course page" : "Direkt auf der Kursseite dokumentiert")</span>
                        }
                        else
                        {
                            <a class="inline-link" href="@link.Url" target="_blank" rel="noreferrer">@(CurrentLanguage == SiteLanguage.En ? "Open material" : "Material oeffnen")</a>
                        }
                    </article>
                }
            </div>
        </section>
    }
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private SiteLanguage CurrentLanguage;
    private LectureDetailViewModel? _lecture;

    protected override void OnParametersSet()
    {
        CurrentLanguage = SiteRoutes.GetLanguage(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));
        _lecture = ContentService.GetLectureBySlug(CurrentLanguage, Slug);
    }
}