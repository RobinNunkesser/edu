@page "/lehre/{Slug}"
@inject SiteContentService ContentService

<PageTitle>Lehrveranstaltung</PageTitle>

@if (_lecture is null)
{
    <section class="page-intro">
        <p class="section-label">Lehre</p>
        <h1>Lehrveranstaltung nicht gefunden</h1>
        <p>Fuer diese Route ist noch keine Unterseite hinterlegt.</p>
    </section>
}
else
{
    <section class="page-intro lecture-hero">
        <div>
            <p class="section-label">Lehre</p>
            <h1>@_lecture.Title</h1>
            <p>@_lecture.Summary</p>
        </div>

        <div class="lecture-meta-card">
            <p class="feature-card-kicker">Rahmen</p>
            <h2>@_lecture.Semester</h2>
            <a class="inline-link" href="@_lecture.SourceUrl" target="_blank" rel="noreferrer">Quelle im lectures-Wiki</a>
        </div>
    </section>

    <section class="page-section">
        <div class="tag-row">
            @foreach (var tag in _lecture.HighlightTags)
            {
                <span class="tag">@tag</span>
            }
        </div>
    </section>

    @foreach (var lectureSection in _lecture.Sections)
    {
        <section class="page-section">
            <div class="section-heading">
                <h2>@lectureSection.Title</h2>
                <p>@lectureSection.Intro</p>
            </div>

            <div class="resource-grid">
                @foreach (var link in lectureSection.Links)
                {
                    <article class="resource-card">
                        <h3>@link.Title</h3>
                        <p>@link.Description</p>
                        @if (string.IsNullOrWhiteSpace(link.Url))
                        {
                            <span class="resource-inline-note">Direkt auf der Kursseite dokumentiert</span>
                        }
                        else
                        {
                            <a class="inline-link" href="@link.Url" target="_blank" rel="noreferrer">Material oeffnen</a>
                        }
                    </article>
                }
            </div>
        </section>
    }
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private LectureDetailViewModel? _lecture;

    protected override void OnParametersSet()
    {
        _lecture = ContentService.GetLectureBySlug(Slug);
    }
}