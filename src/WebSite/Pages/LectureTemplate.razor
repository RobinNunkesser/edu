@page "/lehre/template"
@page "/en/teaching/template"
@inject NavigationManager NavigationManager
@inject SiteContentService ContentService
@inject HttpClient HttpClient

@using System.Net.Http.Json

<PageTitle>@PageTitleText</PageTitle>

<LecturePageTemplate LandingLabel="@LandingLabel" UiText="@UiText" Lecture="@TemplateLecture" />

@code {
    private SiteLanguage CurrentLanguage;
    private string LandingLabel = string.Empty;
    private string PageTitleText = string.Empty;
    private UiTextViewModel? UiText;
    private LectureDetailViewModel? TemplateLecture;

    protected override async Task OnParametersSetAsync()
    {
        CurrentLanguage = SiteRoutes.GetLanguage(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));
        LandingLabel = CurrentLanguage == SiteLanguage.En ? "Teaching" : "Lehre";
        PageTitleText = CurrentLanguage == SiteLanguage.En ? "Course Template" : "Veranstaltungsvorlage";
        UiText = await ContentService.GetUiTextAsync(CurrentLanguage);
        TemplateLecture = await LoadTemplateLectureAsync(CurrentLanguage);
    }

    private async Task<LectureDetailViewModel> LoadTemplateLectureAsync(SiteLanguage language)
    {
        var fileName = language == SiteLanguage.En ? "lecture-template.en.json" : "lecture-template.de.json";
        var content = await HttpClient.GetFromJsonAsync<TemplateLectureContent>($"content/site/{fileName}")
            ?? throw new InvalidOperationException($"Could not load template lecture content from {fileName}.");

        return new LectureDetailViewModel(
            content.Slug,
            content.Title,
            content.Semester,
            content.Summary,
            content.SourceUrl,
            content.HighlightTags,
            content.Sections);
    }

    private sealed record TemplateLectureContent(
        string Slug,
        string Title,
        string Semester,
        string Summary,
        string SourceUrl,
        IReadOnlyList<string> HighlightTags,
        IReadOnlyList<LectureSectionViewModel> Sections);
}