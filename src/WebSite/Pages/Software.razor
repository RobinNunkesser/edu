@page "/software"
@page "/en/software"
@inject NavigationManager NavigationManager
@inject SiteContentService ContentService

<PageTitle>Software</PageTitle>

@if (Cards.Count > 0)
{
    <section class="page-section">
        <div class="feature-grid">
            @foreach (var card in Cards)
            {
                if (string.IsNullOrWhiteSpace(card.Url))
                {
                    <article class="feature-card feature-card-static">
                        <p class="feature-card-kicker">@card.Kicker</p>
                        <h3>@card.Title</h3>
                        <p>@card.Text</p>
                    </article>
                }
                else
                {
                    <a class="feature-card" href="@card.Url" target="_blank" rel="noreferrer">
                        <p class="feature-card-kicker">@card.Kicker</p>
                        <h3>@card.Title</h3>
                        <p>@card.Text</p>
                    </a>
                }
            }
        </div>
    </section>
}

@code {
    private IReadOnlyList<InfoCardViewModel> Cards = [];

    protected override async Task OnParametersSetAsync()
    {
        var currentLanguage = SiteRoutes.GetLanguage(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));
        Cards = await ContentService.GetSoftwareCardsAsync(currentLanguage);
    }
}