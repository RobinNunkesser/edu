@page "/lehre"
@page "/study"
@page "/en/teaching"
@inject NavigationManager NavigationManager
@inject SiteContentService ContentService

<PageTitle>Lehre</PageTitle>

<section class="page-intro">
	<p class="section-label">@(CurrentLanguage == SiteLanguage.En ? "Teaching" : "Lehre")</p>
	<h1>@(CurrentLanguage == SiteLanguage.En ? "Courses with direct access to exercises and materials" : "Lehrveranstaltungen mit direktem Zugriff auf Uebungen und Materialien")</h1>
	<p>
		@(CurrentLanguage == SiteLanguage.En
			? "The first iteration adopts structure and content from the lectures wiki. Course pages should not just list links, but keep the most relevant working materials within immediate reach."
			: "Der erste Ausbau uebernimmt Struktur und Inhalte aus dem lectures-Wiki. Kursseiten sollen nicht nur auflisten, sondern die wichtigsten Arbeitsmaterialien direkt in Reichweite bringen.")
	</p>
</section>

<section class="page-section">
	<div class="feature-grid">
		@foreach (var lecture in Lectures)
		{
			<a class="feature-card" href="@lecture.Route">
				<p class="feature-card-kicker">@lecture.Semester</p>
				<h3>@lecture.Title</h3>
				<p>@lecture.Summary</p>
				<div class="tag-row">
					@foreach (var tag in lecture.HighlightTags)
					{
						<span class="tag">@tag</span>
					}
				</div>
			</a>
		}
	</div>
</section>

@code {
	private SiteLanguage CurrentLanguage;
	private IReadOnlyList<LectureOverviewViewModel> Lectures = [];

	protected override void OnParametersSet()
	{
		CurrentLanguage = SiteRoutes.GetLanguage(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));
		Lectures = ContentService.GetTeachingLectures(CurrentLanguage);
	}
}