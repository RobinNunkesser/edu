    protected override async Task OnParametersSetAsync()
    {
        CurrentLanguage = SiteRoutes.GetLanguage(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));
        var resolvedSlug = string.IsNullOrWhiteSpace(Slug)
            ? (CurrentLanguage == SiteLanguage.En ? "graph-visualization" : "graph-visualisierung")
            : Slug;
        _topic = await TopicService.GetTopicDetailAsync(CurrentLanguage, resolvedSlug);
        CurrentStep = 0;
        _selectedAlgorithmKey = _topic?.NQueens?.Algorithms.FirstOrDefault()?.Key ?? string.Empty;
        _selectedExerciseKey = _topic?.ExerciseDocumentKey ?? string.Empty;
        _activeExerciseDocument = _topic?.ExerciseDocument;
        _useRuntimeExerciseDocument = false;
        ShowExerciseSolution = false;
        InteractiveExerciseMode = true;
        InitializeExerciseAnswers();

        NotFoundLabel = CurrentLanguage == SiteLanguage.En ? "Study topic" : "Studienthema";
        NotFoundTitle = CurrentLanguage == SiteLanguage.En ? "Topic not found" : "Thema nicht gefunden";
        NotFoundText = CurrentLanguage == SiteLanguage.En
            ? "There is no technical slice for this slug yet."
            : "Zu diesem Slug gibt es noch keinen technischen Durchstich.";
    }

    private void PreviousStep()
    {
        if (CurrentStep > 0)
        {
            CurrentStep--;
        }
    }

    private void NextStep()
    {
        if (_topic is not null && CurrentStep < CurrentStepCount)
        {
            CurrentStep++;
        }
    }

    private void ShowCompleteSolution()
    {
        if (_topic is not null)
        {
            CurrentStep = CurrentStepCount;
        }
    }

    private void Reset() => CurrentStep = 0;

    private void SelectAlgorithm(string key)
    {
        _selectedAlgorithmKey = key;
        CurrentStep = 0;
    }

    private void ToggleExerciseSolution() => ShowExerciseSolution = !ShowExerciseSolution;

    private void SetExerciseMode(bool interactiveMode) => InteractiveExerciseMode = interactiveMode;

    private void ResetExerciseAnswers() => InitializeExerciseAnswers();

    private async Task SelectExerciseDocumentAsync(string exerciseKey)
    {
        _selectedExerciseKey = exerciseKey;
        _useRuntimeExerciseDocument = false;
        _activeExerciseDocument = await TopicService.GetExerciseDocumentAsync(CurrentLanguage, exerciseKey);
        ShowExerciseSolution = false;
        InitializeExerciseAnswers();
    }

    private async Task GenerateFreshExerciseAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedExerciseKey))
        {
            return;
        }

        _useRuntimeExerciseDocument = true;
        _activeExerciseDocument = await TopicService.GetExerciseDocumentAsync(CurrentLanguage, _selectedExerciseKey, forceRuntime: true);
        ShowExerciseSolution = false;
        InitializeExerciseAnswers();
    }

    private async Task RestoreImportedExerciseAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedExerciseKey))
        {
            return;
        }

        _useRuntimeExerciseDocument = false;
        _activeExerciseDocument = await TopicService.GetExerciseDocumentAsync(CurrentLanguage, _selectedExerciseKey);
        ShowExerciseSolution = false;
        InitializeExerciseAnswers();
    }

    private async Task PrintExercise()
    {
        InteractiveExerciseMode = false;
        await InvokeAsync(StateHasChanged);
        await JsRuntime.InvokeVoidAsync("print");
    }

    private string FormatBinaryAddition(BinaryAdditionVariantViewModel variant)
    {
        var resultLine = ShowExerciseSolution ? variant.Sum : new string('_', variant.Sum.Length);
        var separator = new string('-', variant.Sum.Length);

        return $"  {variant.LeftAddend}\n+ {variant.RightAddend}\n  {separator}\n  {resultLine}";
    }

    private static string FormatBinaryAdditionPrompt(BinaryAdditionVariantViewModel variant)
    {
        var separator = new string('-', variant.Sum.Length);
        return $"  {variant.LeftAddend}\n+ {variant.RightAddend}\n  {separator}\n  {new string('_', variant.Sum.Length)}";
    }

    private string FormatPromptAnswer(string answer)
        => ShowExerciseSolution ? answer : new string('_', Math.Max(6, answer.Length));

    private void InitializeExerciseAnswers()
    {
        _exerciseAnswers.Clear();

        if (CurrentExerciseDocument is null)
        {
            return;
        }

        foreach (var section in CurrentExerciseDocument.Sections)
        {
            foreach (var block in section.Blocks)
            {
                switch (block)
                {
                    case ExerciseBinaryAdditionBlockViewModel addition:
                        foreach (var variant in addition.Variants)
                        {
                            _exerciseAnswers[GetExerciseAnswerKey(addition.Title, variant.Label)] = string.Empty;
                        }
                        break;
                    case ExercisePromptAnswerBlockViewModel promptAnswer:
                        foreach (var variant in promptAnswer.Variants)
                        {
                            _exerciseAnswers[GetExerciseAnswerKey(promptAnswer.Title, variant.Label)] = string.Empty;
                        }
                        break;
                }
            }
        }
    }

    private static string GetExerciseAnswerKey(string blockTitle, string variantLabel) => $"{blockTitle}:{variantLabel}";

    private string GetExerciseAnswer(string key) => _exerciseAnswers.TryGetValue(key, out var value) ? value : string.Empty;

    private void SetExerciseAnswer(string key, string value) => _exerciseAnswers[key] = value;

    private string GetExerciseAnswerCssClass(string key, string expectedAnswer)
    {
        var answer = GetExerciseAnswer(key);
        if (string.IsNullOrWhiteSpace(answer))
        {
            return string.Empty;
        }

        return AreAnswersEquivalent(answer, expectedAnswer)
            ? "exercise-answer-input-correct"
            : "exercise-answer-input-incorrect";
    }

    private string GetExerciseAnswerFeedback(string key, string expectedAnswer)
    {
        var answer = GetExerciseAnswer(key);
        if (string.IsNullOrWhiteSpace(answer))
        {
            return string.Empty;
        }

        if (AreAnswersEquivalent(answer, expectedAnswer))
        {
            return CurrentLanguage == SiteLanguage.En ? "Correct" : "Korrekt";
        }

        var normalizedActual = NormalizeAnswer(answer);
        var normalizedExpected = NormalizeAnswer(expectedAnswer);

        if (IsBinary(normalizedExpected))
        {
            if (!IsBinary(normalizedActual))
            {
                return CurrentLanguage == SiteLanguage.En ? "Please use only 0 and 1." : "Bitte nur 0 und 1 verwenden.";
            }

            if (normalizedActual.Length != normalizedExpected.Length)
            {
                return CurrentLanguage == SiteLanguage.En
                    ? $"Expected {normalizedExpected.Length} bits."
                    : $"Erwartet werden {normalizedExpected.Length} Bit.";
            }

            return CurrentLanguage == SiteLanguage.En ? "The bit pattern is not correct yet." : "Das Bitmuster ist noch nicht korrekt.";
        }

        if (int.TryParse(normalizedExpected, out _))
        {
            if (!int.TryParse(normalizedActual, out _))
            {
                return CurrentLanguage == SiteLanguage.En ? "Please enter a decimal number." : "Bitte eine Dezimalzahl eingeben.";
            }

            return CurrentLanguage == SiteLanguage.En ? "The value is not correct yet." : "Der Wert ist noch nicht korrekt.";
        }

        return CurrentLanguage == SiteLanguage.En ? "Not correct yet" : "Noch nicht korrekt";
    }

    private string GetExerciseOptionClass(string exerciseKey)
        => string.Equals(_selectedExerciseKey, exerciseKey, StringComparison.Ordinal)
            ? "exercise-studio-option exercise-studio-option-active"
            : "exercise-studio-option";

    private static bool AreAnswersEquivalent(string actualAnswer, string expectedAnswer)
    {
        var normalizedActual = NormalizeAnswer(actualAnswer);
        var normalizedExpected = NormalizeAnswer(expectedAnswer);

        if (IsBinary(normalizedActual) && IsBinary(normalizedExpected))
        {
            return NormalizeBinary(normalizedActual) == NormalizeBinary(normalizedExpected);
        }

        return string.Equals(normalizedActual, normalizedExpected, StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizeAnswer(string answer) => answer.Trim().Replace(" ", string.Empty).Replace("_", string.Empty);

    private static bool IsBinary(string value) => value.Length > 0 && value.All(character => character is '0' or '1');

    private static string NormalizeBinary(string value)
    {
        var trimmed = value.TrimStart('0');
        return string.IsNullOrEmpty(trimmed) ? "0" : trimmed;
    }

    private bool IsSelectedAlgorithm(string key) => string.Equals(_selectedAlgorithmKey, key, StringComparison.Ordinal);

    private string GetStepClass(int stepNumber)
    {
        if (stepNumber <= CurrentStep)
        {
            return stepNumber == CurrentStep ? "mst-step-item mst-step-item-current" : "mst-step-item mst-step-item-complete";
        }

        return "mst-step-item";
    }

    private string GetEdgeClass(StudyEdgeViewModel edge)
    {
        if (IsIncluded(edge.EdgeKey))
        {
            return "mst-edge-card mst-edge-card-active";
        }

        return edge.IsPartOfSolution ? "mst-edge-card mst-edge-card-solution" : "mst-edge-card";
    }

    private string GetEdgeStatus(StudyEdgeViewModel edge)
    {
        var isEnglish = CurrentLanguage == SiteLanguage.En;

        if (IsIncluded(edge.EdgeKey))
        {
            return isEnglish ? "Currently selected" : "Aktuell ausgewaehlt";
        }

        if (edge.IsPartOfSolution)
        {
            return isEnglish ? "Part of final tree" : "Teil der finalen Loesung";
        }

        if (CurrentGraphState.SuccessorEdgeKeys.Contains(edge.EdgeKey))
        {
            return isEnglish ? "Current candidate" : "Aktueller Kandidat";
        }

        return isEnglish ? "Alternative edge" : "Alternative Kante";
    }

    private bool IsIncluded(string edgeKey) => CurrentGraphState.ActiveEdgeKeys.Contains(edgeKey);

    private string GetBoardCellClass(int column, int row)
    {
        var classes = new List<string>
        {
            "nq-cell",
            ((row + column) % 2 == 0) ? "nq-cell-light" : "nq-cell-dark"
        };

        if (CurrentBoardRows.Count > column && CurrentBoardRows[column] == row)
        {
            classes.Add("nq-cell-has-queen");
        }

        if (CurrentNQueensStep?.ConflictedColumns.Contains(column) == true && CurrentBoardRows[column] == row)
        {
            classes.Add("nq-cell-conflict");
        }

        if (CurrentNQueensStep?.CurrentColumn == column && CurrentNQueensStep?.CurrentRow == row)
        {
            classes.Add("nq-cell-current");
        }
        else if (CurrentNQueensStep?.CurrentColumn == column && CurrentBoardRows[column] == row)
        {
            classes.Add("nq-cell-column-focus");
        }

        return string.Join(" ", classes);
    }

    private string GetBoardCellTitle(int column, int row)
    {
        var hasQueen = CurrentBoardRows.Count > column && CurrentBoardRows[column] == row;
        if (!hasQueen)
        {
            return $"({column + 1}, {row + 1})";
        }

        return CurrentLanguage == SiteLanguage.En
            ? $"Queen {column + 1} on row {row + 1}"
            : $"Dame {column + 1} in Zeile {row + 1}";
    }

    private static int CountNQueensConflicts(IReadOnlyList<int> queenRows)
    {
        var conflicts = 0;
        for (var leftColumn = 0; leftColumn < queenRows.Count; leftColumn++)
        {
            for (var rightColumn = leftColumn + 1; rightColumn < queenRows.Count; rightColumn++)
            {
                if (queenRows[leftColumn] == queenRows[rightColumn]
                    || Math.Abs(queenRows[leftColumn] - queenRows[rightColumn]) == Math.Abs(leftColumn - rightColumn))
                {
                    conflicts++;
                }
            }
        }

        return conflicts;
    }

