@page "/study/{Slug}"
@page "/study/graph-visualisierung"
@page "/study/binaer-zu-dezimal"
@page "/study/dezimal-zu-binaer"
@page "/study/zweierkomplement"
@page "/en/study/{Slug}"
@page "/en/study/graph-visualization"
@page "/en/study/binary-to-decimal"
@page "/en/study/decimal-to-binary"
@page "/en/study/twos-complement"
@using Content.Schema
@inject IJSRuntime JsRuntime
@inject NavigationManager NavigationManager
@inject StudyTopicService TopicService

<PageTitle>@(_topic?.Title ?? NotFoundTitle)</PageTitle>

@if (_topic is null)
{
    <section class="page-intro">
        <p class="section-label">@NotFoundLabel</p>
        <h1>@NotFoundTitle</h1>
        <p>@NotFoundText</p>
    </section>
}
else if (IsExerciseTopic && CurrentExerciseDocument is not null)
{
    <section class="page-intro lecture-hero">
        <div>
            <p class="section-label">@_topic.SectionLabel</p>
            <h1>@_topic.Title</h1>
            <p>@_topic.Intro</p>
        </div>

        <div class="lecture-meta-card">
            <p class="feature-card-kicker">@_topic.MetaLabel</p>
            <h2>@_topic.MetaValue</h2>
            <a class="inline-link" href="@_topic.BackRoute">@_topic.BackLabel</a>
        </div>
    </section>

    <section class="page-section">
        <div class="tag-row">
            @foreach (var fact in _topic.Facts)
            {
                <span class="tag">@fact.Label: @fact.Value</span>
            }
        </div>
    </section>

    @if (IsExerciseStudio)
    {
        <section class="page-section exercise-studio-card resource-card">
            <div class="section-heading">
                <h2>@ExerciseStudioTitle</h2>
                <p>@ExerciseStudioIntro</p>
            </div>

            <div class="exercise-studio-grid">
                @foreach (var option in CurrentExerciseOptions)
                {
                    <button class="@GetExerciseOptionClass(option.Key)" @onclick="() => SelectExerciseDocumentAsync(option.Key)">
                        <strong>@option.Title</strong>
                        <span>@option.Summary</span>
                    </button>
                }
            </div>
        </section>
    }

    <section class="page-section exercise-toolbar">
        @if (IsExerciseStudio)
        {
            <span class="exercise-toolbar-topic">@SelectedExerciseTitle</span>
            <button class="btn btn-outline-primary" @onclick="GenerateFreshExerciseAsync">@FreshVariantLabel</button>
            <button class="btn btn-outline-primary" @onclick="RestoreImportedExerciseAsync" disabled="@(!_useRuntimeExerciseDocument)">@ImportedVariantLabel</button>
        }
        <button class="@(InteractiveExerciseMode ? "btn btn-primary" : "btn btn-outline-primary")" @onclick="() => SetExerciseMode(true)">@InteractiveModeLabel</button>
        <button class="@(!InteractiveExerciseMode ? "btn btn-primary" : "btn btn-outline-primary")" @onclick="() => SetExerciseMode(false)">@WorksheetModeLabel</button>
        <button class="btn btn-outline-primary" @onclick="ToggleExerciseSolution">
            @(ShowExerciseSolution ? CurrentExerciseDocument.HideSolutionLabel : CurrentExerciseDocument.ShowSolutionLabel)
        </button>
        <button class="btn btn-outline-primary" @onclick="ResetExerciseAnswers">@ResetExerciseLabel</button>
        <button class="btn btn-primary" @onclick="PrintExercise">@CurrentExerciseDocument.PrintLabel</button>
        <span class="exercise-toolbar-hint">@(InteractiveExerciseMode ? InteractiveModeHint : CurrentExerciseDocument.PrintHint)</span>
    </section>

    <section class="page-section resource-card exercise-document-card">
        <div class="section-heading">
            <h2>@CurrentExerciseDocument.Title</h2>
            <p>@CurrentExerciseDocument.Intro</p>
        </div>

        <div class="resource-table">
            <div class="resource-table-row">
                <div class="resource-table-label">@CurrentExerciseDocument.SourceLabel</div>
                <div class="resource-table-value">@CurrentExerciseDocument.SourceValue</div>
            </div>
        </div>

        <div class="exercise-screen-content">
            @foreach (var exerciseSection in CurrentExerciseDocument.Sections)
            {
                <section class="exercise-section-card">
                    <div class="section-heading">
                        <h3>@exerciseSection.Title</h3>
                        <p>@exerciseSection.Intro</p>
                    </div>

                    @foreach (var block in exerciseSection.Blocks)
                    {
                        if (block is ExerciseParagraphBlockViewModel paragraph)
                        {
                            <p class="exercise-paragraph">@paragraph.Text</p>
                        }
                        else if (block is ExerciseBinaryAdditionBlockViewModel addition)
                        {
                            <section class="exercise-binary-block">
                                <div class="section-heading">
                                    <h3>@addition.Title</h3>
                                    <p>@addition.Intro</p>
                                </div>

                                <div class="resource-grid exercise-variant-grid">
                                    @foreach (var variant in addition.Variants)
                                    {
                                        <article class="resource-card exercise-variant-card">
                                            <p class="feature-card-kicker">@variant.Label</p>
                                            @if (InteractiveExerciseMode)
                                            {
                                                var answerKey = GetExerciseAnswerKey(addition.Title, variant.Label);
                                                <div class="exercise-prompt-answer-grid">
                                                    <div>
                                                        <p class="exercise-solution-caption">@addition.Title</p>
                                                        <pre class="binary-addition-pre">@FormatBinaryAdditionPrompt(variant)</pre>
                                                    </div>
                                                    <div>
                                                        <p class="exercise-solution-caption">@ExerciseAnswerLabel</p>
                                                        <input class="exercise-answer-input @GetExerciseAnswerCssClass(answerKey, variant.Sum)"
                                                               value="@GetExerciseAnswer(answerKey)"
                                                               @oninput="eventArgs => SetExerciseAnswer(answerKey, eventArgs.Value?.ToString() ?? string.Empty)" />
                                                        <p class="exercise-answer-feedback">@GetExerciseAnswerFeedback(answerKey, variant.Sum)</p>
                                                        @if (ShowExerciseSolution)
                                                        {
                                                            <p class="exercise-solution-caption">@addition.SolutionLabel</p>
                                                            <pre class="binary-addition-pre">@variant.Sum</pre>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <pre class="binary-addition-pre">@FormatBinaryAddition(variant)</pre>
                                                @if (ShowExerciseSolution)
                                                {
                                                    <p class="exercise-solution-caption">@addition.SolutionLabel</p>
                                                }
                                            }
                                        </article>
                                    }
                                </div>
                            </section>
                        }
                        else if (block is ExercisePromptAnswerBlockViewModel promptAnswer)
                        {
                            <section class="exercise-binary-block">
                                <div class="section-heading">
                                    <h3>@promptAnswer.Title</h3>
                                    <p>@promptAnswer.Intro</p>
                                </div>

                                <div class="resource-grid exercise-variant-grid">
                                    @foreach (var variant in promptAnswer.Variants)
                                    {
                                        <article class="resource-card exercise-variant-card">
                                            <p class="feature-card-kicker">@variant.Label</p>
                                            @if (InteractiveExerciseMode)
                                            {
                                                var answerKey = GetExerciseAnswerKey(promptAnswer.Title, variant.Label);
                                                <div class="exercise-prompt-answer-grid">
                                                    <div>
                                                        <p class="exercise-solution-caption">@promptAnswer.PromptLabel</p>
                                                        <pre class="binary-addition-pre">@variant.Prompt</pre>
                                                    </div>
                                                    <div>
                                                        <p class="exercise-solution-caption">@ExerciseAnswerLabel</p>
                                                        <input class="exercise-answer-input @GetExerciseAnswerCssClass(answerKey, variant.Answer)"
                                                               value="@GetExerciseAnswer(answerKey)"
                                                               @oninput="eventArgs => SetExerciseAnswer(answerKey, eventArgs.Value?.ToString() ?? string.Empty)" />
                                                        <p class="exercise-answer-feedback">@GetExerciseAnswerFeedback(answerKey, variant.Answer)</p>
                                                        @if (ShowExerciseSolution)
                                                        {
                                                            <p class="exercise-solution-caption">@promptAnswer.SolutionLabel</p>
                                                            <pre class="binary-addition-pre">@variant.Answer</pre>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="exercise-prompt-answer-grid">
                                                    <div>
                                                        <p class="exercise-solution-caption">@promptAnswer.PromptLabel</p>
                                                        <pre class="binary-addition-pre">@variant.Prompt</pre>
                                                    </div>
                                                    <div>
                                                        <p class="exercise-solution-caption">@(ShowExerciseSolution ? promptAnswer.SolutionLabel : promptAnswer.AnswerLabel)</p>
                                                        <pre class="binary-addition-pre">@FormatPromptAnswer(variant.Answer)</pre>
                                                    </div>
                                                </div>
                                            }
                                        </article>
                                    }
                                </div>
                            </section>
                        }
                    }
                </section>
            }
        </div>

        <section class="exercise-print-sheet" aria-hidden="true">
            <header class="exercise-print-header">
                <div>
                    <p class="exercise-print-kicker">@_topic.SectionLabel</p>
                    <h2>@SelectedExerciseTitle</h2>
                    <p class="exercise-print-intro">@CurrentExerciseDocument.Intro</p>
                </div>

                <div class="exercise-print-meta">
                    <div class="exercise-print-field">
                        <span>@PrintNameLabel</span>
                        <div class="exercise-print-line"></div>
                    </div>
                    <div class="exercise-print-field">
                        <span>@PrintCourseLabel</span>
                        <div class="exercise-print-line"></div>
                    </div>
                    <div class="exercise-print-field-grid">
                        <div class="exercise-print-field">
                            <span>@PrintDateLabel</span>
                            <div class="exercise-print-line"></div>
                        </div>
                        <div class="exercise-print-field">
                            <span>@PrintGroupLabel</span>
                            <div class="exercise-print-line"></div>
                        </div>
                    </div>
                </div>
            </header>

            <div class="exercise-print-source">
                <strong>@CurrentExerciseDocument.SourceLabel:</strong> @CurrentExerciseDocument.SourceValue
            </div>

            @foreach (var exerciseSection in CurrentExerciseDocument.Sections)
            {
                <section class="exercise-print-section">
                    <div class="exercise-print-section-header">
                        <h3>@exerciseSection.Title</h3>
                        <p>@exerciseSection.Intro</p>
                    </div>

                    @foreach (var block in exerciseSection.Blocks)
                    {
                        if (block is ExerciseParagraphBlockViewModel paragraph)
                        {
                            <p class="exercise-print-paragraph">@paragraph.Text</p>
                        }
                        else if (block is ExerciseBinaryAdditionBlockViewModel addition)
                        {
                            <section class="exercise-print-block">
                                <p class="exercise-print-block-title">@addition.Title</p>
                                <p class="exercise-print-block-intro">@addition.Intro</p>

                                <div class="exercise-print-addition-grid">
                                    @foreach (var variant in addition.Variants)
                                    {
                                        <article class="exercise-print-addition-card">
                                            <div class="exercise-print-variant-label">@variant.Label</div>
                                            <div class="exercise-print-sum">
                                                <div class="exercise-print-sum-line">@variant.LeftAddend</div>
                                                <div class="exercise-print-sum-line">+ @variant.RightAddend</div>
                                                <div class="exercise-print-sum-separator"></div>
                                                <div class="exercise-print-sum-line">@(ShowExerciseSolution ? variant.Sum : new string('_', variant.Sum.Length))</div>
                                            </div>
                                        </article>
                                    }
                                </div>
                            </section>
                        }
                        else if (block is ExercisePromptAnswerBlockViewModel promptAnswer)
                        {
                            <section class="exercise-print-block">
                                <p class="exercise-print-block-title">@promptAnswer.Title</p>
                                <p class="exercise-print-block-intro">@promptAnswer.Intro</p>

                                <table class="exercise-print-table">
                                    <thead>
                                        <tr>
                                            <th>@PrintNumberLabel</th>
                                            <th>@promptAnswer.PromptLabel</th>
                                            <th>@(ShowExerciseSolution ? promptAnswer.SolutionLabel : promptAnswer.AnswerLabel)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var variant in promptAnswer.Variants)
                                        {
                                            <tr>
                                                <td>@variant.Label</td>
                                                <td><span class="exercise-print-mono">@variant.Prompt</span></td>
                                                <td>
                                                    @if (ShowExerciseSolution)
                                                    {
                                                        <span class="exercise-print-mono">@variant.Answer</span>
                                                    }
                                                    else
                                                    {
                                                        <div class="exercise-print-answer-lines">
                                                            <div class="exercise-print-answer-line"></div>
                                                            <div class="exercise-print-answer-line"></div>
                                                        </div>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </section>
                        }
                    }
                </section>
            }
        </section>
    </section>
}
else
{
    <section class="page-intro lecture-hero mst-hero">
        <div>
            <p class="section-label">@_topic.SectionLabel</p>
            <h1>@_topic.Title</h1>
            <p>@_topic.Intro</p>
        </div>

        <div class="lecture-meta-card">
            <p class="feature-card-kicker">@_topic.MetaLabel</p>
            <h2>@_topic.MetaValue</h2>
            <a class="inline-link" href="@_topic.BackRoute">@_topic.BackLabel</a>
        </div>
    </section>

    <section class="page-section">
        <div class="tag-row">
            @foreach (var fact in _topic.Facts)
            {
                <span class="tag">@fact.Label: @fact.Value</span>
            }
        </div>
    </section>

    <section class="page-section mst-layout">
        <article class="resource-card mst-card">
            <div class="section-heading">
                <h2>@_topic.StepSectionTitle</h2>
                <p>@_topic.StepSectionIntro</p>
            </div>

            @if (IsNQueensTopic)
            {
                <div class="nq-algorithm-switcher" role="tablist" aria-label="@CurrentNQueensTopic!.AlgorithmSelectorLabel">
                    @foreach (var algorithm in CurrentNQueensTopic.Algorithms)
                    {
                        <button class="@(IsSelectedAlgorithm(algorithm.Key) ? "btn btn-primary" : "btn btn-outline-primary")"
                                @onclick="() => SelectAlgorithm(algorithm.Key)">
                            @algorithm.Name
                        </button>
                    }
                </div>

                <div class="mst-progress-card">
                    <p class="feature-card-kicker">@CurrentNQueensTopic.AlgorithmSelectorLabel</p>
                    <h3>@CurrentNQueensAlgorithm!.Name</h3>
                    <p>@CurrentNQueensAlgorithm.Summary</p>
                </div>
            }

            <div class="mst-controls">
                <button class="btn btn-outline-primary" @onclick="PreviousStep" disabled="@(CurrentStep == 0)">@_topic.PreviousStepLabel</button>
                <button class="btn btn-primary" @onclick="NextStep" disabled="@(CurrentStep >= CurrentStepCount)">@_topic.NextStepLabel</button>
                <button class="btn btn-outline-primary" @onclick="ShowCompleteSolution" disabled="@(CurrentStep >= CurrentStepCount)">@_topic.CompleteSolutionLabel</button>
                <button class="btn btn-link" @onclick="Reset">@_topic.ResetLabel</button>
            </div>

            <div class="mst-progress-card">
                <p class="feature-card-kicker">@_topic.ProgressLabel</p>
                <h3>@ProgressText</h3>
                <p>@CurrentStepDescription</p>
            </div>

            <ol class="mst-step-list">
                @foreach (var step in CurrentStepItems)
                {
                    <li class="@GetStepClass(step.Number)">
                        <div>
                            <strong>@step.Number. @step.Title</strong>
                            <p>@step.Description</p>
                        </div>
                        <span class="tag">@step.Badge</span>
                    </li>
                }
            </ol>
        </article>

        <article class="resource-card mst-card">
            <div class="section-heading">
                <h2>@VisualSectionTitle</h2>
                <p>@VisualSectionIntro</p>
            </div>

            @if (IsNQueensTopic)
            {
                <div class="nq-board-shell">
                    <div class="nq-board" style="--board-size:@CurrentBoardSize">
                        @for (var row = 0; row < CurrentBoardSize; row++)
                        {
                            @for (var column = 0; column < CurrentBoardSize; column++)
                            {
                                <div class="@GetBoardCellClass(column, row)" title="@GetBoardCellTitle(column, row)">
                                    @if (CurrentBoardRows[column] == row)
                                    {
                                        <span class="nq-queen">Q</span>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <div class="nq-inspector-grid">
                        <article class="mst-edge-card @(CurrentNQueensStep?.Solved == true ? "mst-edge-card-active" : string.Empty)">
                            <p class="feature-card-kicker">@CurrentNQueensTopic!.BoardSizeLabel</p>
                            <h3>@CurrentBoardSize x @CurrentBoardSize</h3>
                            <p>@CurrentNQueensTopic!.ConflictCountLabel: @CurrentConflictCount</p>
                        </article>
                        <article class="mst-edge-card @(CurrentNQueensStep?.Stopped == true ? "mst-edge-card-solution" : string.Empty)">
                            <p class="feature-card-kicker">@CurrentNQueensTopic!.CurrentMoveLabel</p>
                            <h3>@CurrentActionTitle</h3>
                            <p>@CurrentActionMetric</p>
                        </article>
                    </div>
                </div>
            }
            else
            {
                <GraphViewport Graph="@CurrentGraphVisualization"
                               ActiveEdgeKeys="@CurrentGraphState.ActiveEdgeKeys"
                               ActiveNodeKeys="@CurrentGraphState.ActiveNodeIds"
                               FrontierNodeKeys="@CurrentGraphState.FrontierNodeIds"
                               ExploredNodeKeys="@CurrentGraphState.ExploredNodeIds"
                               CurrentNodeKey="@CurrentGraphState.CurrentNodeId"
                               SuccessorEdgeKeys="@CurrentGraphState.SuccessorEdgeKeys"
                               DirectedActiveEdgeIds="@CurrentGraphState.DirectedActiveEdgeIds"
                               DirectedSuccessorEdgeIds="@CurrentGraphState.DirectedSuccessorEdgeIds"
                               Title="@_topic.GraphSectionTitle"
                               ZoomInLabel="@GraphZoomInLabel"
                               ZoomOutLabel="@GraphZoomOutLabel"
                               FitLabel="@GraphFitLabel"
                               ResetLabel="@GraphResetLabel"
                               InteractionHint="@GraphInteractionHint"
                               ActiveLegendLabel="@GraphLegendActiveLabel"
                               SuccessorLegendLabel="@GraphLegendSuccessorLabel"
                               CurrentNodeLegendLabel="@GraphLegendCurrentNodeLabel"
                               FrontierLegendLabel="@GraphLegendFrontierLabel"
                               ExploredLegendLabel="@GraphLegendExploredLabel"
                               SolutionLegendLabel="@GraphLegendSolutionLabel"
                               DefaultLegendLabel="@GraphLegendDefaultLabel"
                               InspectorTitle="@GraphInspectorTitle"
                               NoSelectionTitle="@GraphNoSelectionTitle"
                               NoSelectionText="@GraphNoSelectionText"
                               NodeLabel="@GraphNodeLabel"
                               EdgeLabel="@GraphEdgeLabel"
                               WeightLabel="@GraphWeightLabel"
                               ConnectionsLabel="@GraphConnectionsLabel"
                               StateLabel="@GraphStateLabel" />

                <div class="mst-edge-grid">
                    @foreach (var edge in _topic.GraphEdges ?? [])
                    {
                        <article class="@GetEdgeClass(edge)">
                            <div>
                                <p class="feature-card-kicker">@edge.Source - @edge.Target</p>
                                <h3>@edge.Weight</h3>
                            </div>
                            <p>@GetEdgeStatus(edge)</p>
                        </article>
                    }
                </div>
            }
        </article>
    </section>

    <section class="page-section">
        <div class="section-heading">
            <h2>@_topic.ResultSectionTitle</h2>
            <p>@_topic.ResultSectionIntro</p>
        </div>

        <div class="resource-grid">
            @if (IsNQueensTopic)
            {
                <article class="resource-card mst-result-card">
                    <p class="feature-card-kicker">@CurrentNQueensTopic!.AlgorithmSelectorLabel</p>
                    <h3>@CurrentNQueensAlgorithm!.Name</h3>
                    <p>@CurrentNQueensAlgorithm.Summary</p>
                </article>
                <article class="resource-card mst-result-card">
                    <p class="feature-card-kicker">@CurrentNQueensTopic.CurrentAssignmentLabel</p>
                    <h3>@CurrentAssignment</h3>
                    <p>@CurrentNQueensTopic.ConflictCountLabel: @CurrentConflictCount</p>
                </article>
                <article class="resource-card mst-result-card">
                    <p class="feature-card-kicker">@CurrentNQueensTopic.CurrentMoveLabel</p>
                    <h3>@CurrentActionTitle</h3>
                    <p>@CurrentActionMetric</p>
                </article>
            }
            else
            {
                @foreach (var edge in IncludedEdges)
                {
                    <article class="resource-card mst-result-card">
                        <p class="feature-card-kicker">@(CurrentLanguage == SiteLanguage.En ? "Selected edge" : "Ausgewaehlte Kante")</p>
                        <h3>@edge.Source - @edge.Target</h3>
                        <p>@(CurrentLanguage == SiteLanguage.En ? "Weight" : "Gewicht"): @edge.Weight</p>
                    </article>
                }
            }
        </div>
    </section>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private SiteLanguage CurrentLanguage;
    private StudyTopicDetailViewModel? _topic;
    private int CurrentStep;
    private string _selectedAlgorithmKey = string.Empty;
    private string _selectedExerciseKey = string.Empty;
    private ExerciseDocumentViewModel? _activeExerciseDocument;
    private bool _useRuntimeExerciseDocument;
    private string NotFoundLabel = string.Empty;
    private string NotFoundTitle = string.Empty;
    private string NotFoundText = string.Empty;

    private string ProgressText => _topic is null
        ? string.Empty
        : $"{CurrentStep}/{CurrentStepCount}";

    private bool IsNQueensTopic => _topic?.Kind == StudyTopicKind.NQueens;

    private bool IsExerciseTopic => _topic?.Kind == StudyTopicKind.Exercise;

    private ExerciseDocumentViewModel? CurrentExerciseDocument => _activeExerciseDocument ?? _topic?.ExerciseDocument;

    private IReadOnlyList<ExerciseTopicOptionViewModel> CurrentExerciseOptions => _topic?.ExerciseOptions ?? [];

    private bool IsExerciseStudio => CurrentExerciseOptions.Count > 1;

    private bool ShowExerciseSolution;

    private bool InteractiveExerciseMode = true;

    private readonly Dictionary<string, string> _exerciseAnswers = new();

    private NQueensTopicViewModel? CurrentNQueensTopic => _topic?.NQueens;

    private NQueensAlgorithmViewModel? CurrentNQueensAlgorithm => CurrentNQueensTopic?.Algorithms.FirstOrDefault(algorithm => algorithm.Key == _selectedAlgorithmKey)
        ?? CurrentNQueensTopic?.Algorithms.FirstOrDefault();

    private int CurrentStepCount => IsNQueensTopic
        ? CurrentNQueensAlgorithm?.Steps.Count ?? 0
        : _topic?.Steps?.Count ?? 0;

    private IReadOnlyList<StudyStepListItem> CurrentStepItems => IsNQueensTopic
        ? (CurrentNQueensAlgorithm?.Steps.Select(step => new StudyStepListItem(step.Number, step.Summary, step.Metric, step.Description)).ToArray() ?? [])
        : (_topic?.Steps?.Select(step => new StudyStepListItem(step.Number, step.EdgeLabel, step.Weight, step.Description)).ToArray() ?? []);

    private string VisualSectionTitle => IsNQueensTopic
        ? CurrentNQueensTopic?.BoardSectionTitle ?? string.Empty
        : _topic?.GraphSectionTitle ?? string.Empty;

    private string VisualSectionIntro => IsNQueensTopic
        ? CurrentNQueensTopic?.BoardSectionIntro ?? string.Empty
        : _topic?.GraphSectionIntro ?? string.Empty;

    private string GraphZoomInLabel => CurrentLanguage == SiteLanguage.En ? "Zoom in" : "Vergroessern";

    private string GraphZoomOutLabel => CurrentLanguage == SiteLanguage.En ? "Zoom out" : "Verkleinern";

    private string GraphFitLabel => CurrentLanguage == SiteLanguage.En ? "Fit graph" : "Graph einpassen";

    private string GraphResetLabel => CurrentLanguage == SiteLanguage.En ? "Reset" : "Reset";

    private string GraphInteractionHint => CurrentLanguage == SiteLanguage.En
        ? "Drag to pan, use the wheel to zoom, double click to refit, focus for arrow-key panning and click nodes or edges for details."
        : "Zum Verschieben ziehen, mit dem Mausrad zoomen, mit Doppelklick neu einpassen, nach Fokus mit Pfeiltasten verschieben und fuer Details Knoten oder Kanten anklicken.";

    private string GraphLegendActiveLabel => CurrentLanguage == SiteLanguage.En ? "Active solution" : "Aktive Loesung";

    private string GraphLegendSuccessorLabel => CurrentLanguage == SiteLanguage.En ? "Candidate edges" : "Kandidatenkanten";

    private string GraphLegendCurrentNodeLabel => CurrentLanguage == SiteLanguage.En ? "Current node" : "Aktueller Knoten";

    private string GraphLegendFrontierLabel => CurrentLanguage == SiteLanguage.En ? "Frontier" : "Frontier";

    private string GraphLegendExploredLabel => CurrentLanguage == SiteLanguage.En ? "Explored" : "Exploriert";

    private string GraphLegendSolutionLabel => CurrentLanguage == SiteLanguage.En ? "Final solution" : "Finale Loesung";

    private string GraphLegendDefaultLabel => CurrentLanguage == SiteLanguage.En ? "Alternative edge" : "Alternative Kante";

    private string GraphInspectorTitle => CurrentLanguage == SiteLanguage.En ? "Inspector" : "Inspektor";

    private string GraphNoSelectionTitle => CurrentLanguage == SiteLanguage.En ? "Nothing selected" : "Nichts ausgewaehlt";

    private string GraphNoSelectionText => CurrentLanguage == SiteLanguage.En
        ? "Use the graph itself to inspect nodes, edges and the current search or solution state."
        : "Nutze den Graphen selbst, um Knoten, Kanten und den aktuellen Such- oder Loesungszustand zu inspizieren.";

    private string GraphNodeLabel => CurrentLanguage == SiteLanguage.En ? "Node" : "Knoten";

    private string GraphEdgeLabel => CurrentLanguage == SiteLanguage.En ? "Edge" : "Kante";

    private string GraphWeightLabel => CurrentLanguage == SiteLanguage.En ? "Weight" : "Gewicht";

    private string GraphConnectionsLabel => CurrentLanguage == SiteLanguage.En ? "Connections" : "Verbindungen";

    private string GraphStateLabel => CurrentLanguage == SiteLanguage.En ? "State" : "Status";

    private string InteractiveModeLabel => CurrentLanguage == SiteLanguage.En ? "Interactive exercise" : "Interaktive Uebung";

    private string WorksheetModeLabel => CurrentLanguage == SiteLanguage.En ? "Worksheet view" : "Arbeitsblattansicht";

